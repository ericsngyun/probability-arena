# --- Database ---
DATABASE_URL=postgresql+psycopg2://arena:arena@localhost:5432/probability_arena

# --- Redis (candidate-list caching; app degrades gracefully if unreachable) ---
REDIS_URL=redis://localhost:6379/0
CANDIDATES_CACHE_TTL_SECONDS=30

# --- Kalshi REST (public market data needs no credentials) ---
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_REQUEST_TIMEOUT_SECONDS=10
# Server-side exclusion of auto-generated multivariate/parlay markets
# ("exclude" recommended; set empty to fetch them too)
KALSHI_MVE_FILTER=exclude

# --- Kalshi WebSocket snapshots (OPTIONAL — service only starts if BOTH are set) ---
# API key id from https://kalshi.com account settings
KALSHI_API_KEY_ID=
# Path to the RSA private key PEM downloaded when the API key was created
KALSHI_PRIVATE_KEY_PATH=
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
# Comma-separated market tickers to subscribe to; empty = top candidates from last scan
KALSHI_WS_TICKERS=

# --- Scanner / ranking ---
SCANNER_MAX_MARKETS=500
CANDIDATES_DEFAULT_LIMIT=25

# --- Resolution-criteria assessment ---
# LLM judgment is OFF by default; the deterministic rule-based judge always works.
# Enabling requires the `anthropic` package and an Anthropic credential
# (ANTHROPIC_API_KEY, or an `ant auth login` profile).
ENABLE_LLM_RESOLUTION=false
RESOLUTION_MODEL_NAME=claude-opus-4-8
RESOLUTION_PROMPT_VERSION=v1
# Candidates scoring below this are marked needs_manual_review/avoid
MIN_CLARITY_SCORE=0.70

# --- Research packet collection ---
# External (LLM + web search) research is OFF by default; the deterministic
# template collector always works and never touches the web.
ENABLE_EXTERNAL_RESEARCH=false
RESEARCH_COLLECTOR_NAME=template
RESEARCH_COLLECTOR_VERSION=v1
RESEARCH_MODEL_NAME=claude-opus-4-8

# --- Baseball external research canary ---
# Narrow canary, NOT global external research: applies only to PROMOTED
# signals whose domain is sports_baseball with a researchable resolution.
# Evidence comes from the public MLB Stats API (read-only GETs, no key).
ENABLE_BASEBALL_EXTERNAL_RESEARCH=false
BASEBALL_RESEARCH_TIMEOUT_SECONDS=15
BASEBALL_RESEARCH_MAX_SOURCES=8
BASEBALL_RESEARCH_COLLECTOR_VERSION=v1

# --- Soccer / World Cup external research canary ---
# Narrow canary, NOT global external research: applies only to PROMOTED
# signals whose domain is sports_soccer with a researchable resolution.
# SOCCER_RESEARCH_PROVIDER selects the live data source: "template" keeps the
# collector fallback-only (honest template packets) even when the flag is on;
# "espn" enables the public ESPN soccer API (read-only GETs, no key).
ENABLE_SOCCER_EXTERNAL_RESEARCH=false
SOCCER_RESEARCH_PROVIDER=template
SOCCER_RESEARCH_TIMEOUT_SECONDS=15
SOCCER_RESEARCH_MAX_SOURCES=8
SOCCER_RESEARCH_COLLECTOR_VERSION=v1

# --- Baseball evidence-aware forecasting canary ---
# Consumes source-backed MLB research packets (no external calls itself) and
# produces capped, explainable, non-midpoint forecasts for recognized market
# types (totals / spreads / game winner). Everything else stays on the
# template baseline.
ENABLE_BASEBALL_EVIDENCE_FORECASTING=false
BASEBALL_FORECASTER_VERSION=v1
BASEBALL_FORECAST_MAX_CONFIDENCE=0.70
BASEBALL_FORECAST_MIN_COMPLETENESS=0.75

# --- MarketOps Autopilot (OPS-006) ---
# Read-only 24/7 coordination of existing services: auto-promote/process
# signals, crypto scan, outcome sync, scoring, champion/challenger snapshot,
# local DB alerts. It CANNOT trade, paper trade, calculate EV, or move money.
# The flag gates only the loop/timer; marketops-run-once is always allowed.
ENABLE_MARKETOPS_AUTOPILOT=false
MARKETOPS_PROMOTE_LIMIT=5
MARKETOPS_PROCESS_LIMIT=5
MARKETOPS_CRYPTO_SCAN_LIMIT=100
MARKETOPS_SYNC_OUTCOME_LIMIT=500
MARKETOPS_SCORE_LIMIT=1000
MARKETOPS_MIN_SIGNAL_AGE_SECONDS=30
MARKETOPS_MAX_SIGNAL_AGE_HOURS=24
MARKETOPS_INCLUDE_CRYPTO=true
MARKETOPS_INCLUDE_PROBABILITY_MARKETS=true
MARKETOPS_FAIL_FAST=false
MARKETOPS_LOOP_INTERVAL_SECONDS=300

# --- Crypto Arena scout (CRYPTO-001) ---
# Read-only Solana memecoin surveillance: DEX Screener discovery, price/
# liquidity ticks, deterministic informational risk signals. NO wallets, NO
# private keys, NO swaps, NO Jupiter/transaction construction, NO signing,
# NO execution, NO EV, NO paper trading (docs/SAFETY_BOUNDARIES.md).
# ENABLE_CRYPTO_SCOUT reserves loop/timer use (none exists in CRYPTO-001);
# manual `crypto-scan-once` runs are always allowed.
ENABLE_CRYPTO_SCOUT=false
CRYPTO_CHAIN=solana
CRYPTO_PROVIDER=dexscreener
CRYPTO_WATCHER_POLL_INTERVAL_SECONDS=60
CRYPTO_PAIR_LIMIT=100
CRYPTO_MIN_LIQUIDITY_USD=5000
CRYPTO_MIN_VOLUME_5M_USD=1000
CRYPTO_SIGNAL_COOLDOWN_SECONDS=900
# Reserved only — no Helius adapter exists in CRYPTO-001
ENABLE_HELIUS=false
# Optional risk provider; "mock" is the only CRYPTO-001 implementation
ENABLE_CRYPTO_RISK_PROVIDER=false
CRYPTO_RISK_PROVIDER=mock
# Prunes crypto_price_ticks + crypto_watcher_runs only
CRYPTO_RETENTION_DAYS=7

# --- Crypto risk engine (CRYPTO-002) ---
# Read-only risk INTELLIGENCE: heuristics + optional providers produce
# composite risk scores and avoid/flag verdicts for review. A risk score is
# NEVER a trade recommendation; "severe" means avoid/flag, not short/sell.
# API keys are optional, sent as request headers only, and never printed.
ENABLE_CRYPTO_RISK_ENGINE=false
ENABLE_GOPLUS_RISK=false
GOPLUS_API_KEY=
ENABLE_SOLANA_TRACKER_RISK=false
SOLANA_TRACKER_API_KEY=
# Reserved only — no RugCheck adapter exists in CRYPTO-002
ENABLE_RUGCHECK_RISK=false
CRYPTO_RISK_MIN_LIQUIDITY_USD=5000
CRYPTO_RISK_MAX_TOP_HOLDER_PCT=20
CRYPTO_RISK_MAX_SNIPER_PCT=20
CRYPTO_RISK_MAX_INSIDER_PCT=15
CRYPTO_RISK_MAX_BUNDLER_PCT=25
CRYPTO_RISK_MIN_PAIR_AGE_SECONDS=300
CRYPTO_RISK_PROVIDER_TIMEOUT_SECONDS=10
CRYPTO_RISK_ENGINE_VERSION=v1

# --- Retention / pruning ---
# Prunes operational tables only (price ticks, watcher runs, pipeline audit).
# Intelligence/calibration tables (outcomes, forecasts, scores, packets,
# enrichments, assessments) are NEVER pruned.
TICK_RETENTION_DAYS=7
WATCHER_RUN_RETENTION_DAYS=30
PIPELINE_RUN_RETENTION_DAYS=90
# 0 = keep opportunity signals indefinitely
SIGNAL_RETENTION_DAYS=0
RETENTION_BATCH_SIZE=5000
# Run retention as a final baseline-pipeline stage (off by default)
ENABLE_PIPELINE_RETENTION=false
# Let the watcher loop prune at most once per day (off by default)
ENABLE_WATCHER_RETENTION=false

# --- Real-time opportunity watcher ---
# Signals are informational only: no EV, no sizing, no trade directives.
# The loop refuses to start unless ENABLE_REALTIME_WATCHER=true
# (watch-once always works for manual runs).
ENABLE_REALTIME_WATCHER=false
WATCHER_POLL_INTERVAL_SECONDS=60
WATCHER_MARKET_LIMIT=100
# Midpoint move (in dollars) that fires price_move_threshold
WATCHER_PRICE_MOVE_THRESHOLD=0.07
# spread_tightened fires when the spread crosses into <= this band (dollars)
WATCHER_MAX_SPREAD=0.15
# liquidity_appeared fires when liquidity proxy crosses >= this (cents)
WATCHER_MIN_LIQUIDITY_PROXY=100
# Same (ticker, signal_type) is deduped within this window
WATCHER_SIGNAL_COOLDOWN_SECONDS=900

# --- Baseline pipeline runner ---
# Scheduled read-only measurement loop (scan -> ... -> calibration-report).
# Overlapping runs are prevented by a DB lock; a second run exits as skipped.
BASELINE_SCAN_LIMIT=500
BASELINE_CANDIDATE_LIMIT=20
BASELINE_FAIL_FAST=false
BASELINE_SYNC_OUTCOME_LIMIT=200
BASELINE_SCORE_LIMIT=1000

# --- Forecast engine ---
# LLM forecasting is OFF by default; the deterministic template baseline
# always works. Forecasts are probabilities + reasoning only — no EV,
# no sizing, no trade recommendations.
ENABLE_LLM_FORECASTING=false
FORECASTER_NAME=template_baseline
FORECASTER_VERSION=v1
FORECAST_PROMPT_VERSION=v1
FORECAST_MODEL_NAME=claude-opus-4-8
# Deterministic confidence ceilings by evidence depth (enforced in post-
# processing regardless of what any forecaster reports)
TEMPLATE_ONLY_MAX_CONFIDENCE=0.55
SOURCE_BACKED_MAX_CONFIDENCE=0.75
MISSING_CRITICAL_INFO_MAX_CONFIDENCE=0.50

# --- Candidate hygiene / eligibility gating ---
# Markets failing any enabled gate are rejected (rejection_reasons recorded)
# and excluded from /markets/candidates unless include_rejected=true.
REQUIRE_TWO_SIDED_QUOTE=true
EXCLUDE_ZERO_QUOTE_MARKETS=true
MIN_LIQUIDITY=100
MIN_VOLUME_24H=25
# Max yes bid/ask spread in dollars (0.20 = 20 cents)
MAX_SPREAD=0.20
MIN_DAYS_TO_EXPIRATION=0.25
MAX_DAYS_TO_EXPIRATION=45

# --- Operational hardening (OPS-007) ---
# A 'running' marketops cycle older than this is treated as crashed
MARKETOPS_LOCK_STALE_AFTER_MINUTES=30
# SQLite connections wait this long for write locks (Postgres unaffected)
SQLITE_BUSY_TIMEOUT_MS=30000
# Compressed DB snapshots (backup-db / list-db-backups / verify-db-backup)
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=data/backups
