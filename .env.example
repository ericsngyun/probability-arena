# --- Database ---
DATABASE_URL=postgresql+psycopg2://arena:arena@localhost:5432/probability_arena

# --- Redis (candidate-list caching; app degrades gracefully if unreachable) ---
REDIS_URL=redis://localhost:6379/0
CANDIDATES_CACHE_TTL_SECONDS=30

# --- Kalshi REST (public market data needs no credentials) ---
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_REQUEST_TIMEOUT_SECONDS=10
# Server-side exclusion of auto-generated multivariate/parlay markets
# ("exclude" recommended; set empty to fetch them too)
KALSHI_MVE_FILTER=exclude

# --- Kalshi WebSocket snapshots (OPTIONAL — service only starts if BOTH are set) ---
# API key id from https://kalshi.com account settings
KALSHI_API_KEY_ID=
# Path to the RSA private key PEM downloaded when the API key was created
KALSHI_PRIVATE_KEY_PATH=
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
# Comma-separated market tickers to subscribe to; empty = top candidates from last scan
KALSHI_WS_TICKERS=

# --- Scanner / ranking ---
SCANNER_MAX_MARKETS=500
CANDIDATES_DEFAULT_LIMIT=25

# --- Resolution-criteria assessment ---
# LLM judgment is OFF by default; the deterministic rule-based judge always works.
# Enabling requires the `anthropic` package and an Anthropic credential
# (ANTHROPIC_API_KEY, or an `ant auth login` profile).
ENABLE_LLM_RESOLUTION=false
RESOLUTION_MODEL_NAME=claude-opus-4-8
RESOLUTION_PROMPT_VERSION=v1
# Candidates scoring below this are marked needs_manual_review/avoid
MIN_CLARITY_SCORE=0.70

# --- Candidate hygiene / eligibility gating ---
# Markets failing any enabled gate are rejected (rejection_reasons recorded)
# and excluded from /markets/candidates unless include_rejected=true.
REQUIRE_TWO_SIDED_QUOTE=true
EXCLUDE_ZERO_QUOTE_MARKETS=true
MIN_LIQUIDITY=100
MIN_VOLUME_24H=25
# Max yes bid/ask spread in dollars (0.20 = 20 cents)
MAX_SPREAD=0.20
MIN_DAYS_TO_EXPIRATION=0.25
MAX_DAYS_TO_EXPIRATION=45
